rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── User Profile ────────────────────────────────────────────────────────
    // Jeder eingeloggte User darf nur sein eigenes Profil lesen/schreiben
    // Lesen der users-Liste ist für alle erlaubt (für Username-Eindeutigkeit bei Registrierung)
    match /users/{userId} {
      allow list: if true;  // Username-Eindeutigkeit prüfen (nur Query, kein volles Dokument)
      allow get: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;

      // Tokens: nur der eigene User darf lesen/schreiben
      match /tokens/{tokenId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ── Auctions ─────────────────────────────────────────────────────────────
    // Alle eingeloggten User dürfen Auktionen lesen
    // Erstellen: nur mit eigener sellerId
    // Aktualisieren (bieten, stornieren): nur eingeloggte User
    match /auctions/{auctionId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.sellerId == request.auth.uid;
      allow update: if request.auth != null;
      allow delete: if request.auth != null
                    && resource.data.sellerId == request.auth.uid;
    }
  }
}
